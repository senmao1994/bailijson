{"id":902,"name":"明烛","alias":"Milio","title":"米利欧","shortBio":"米利欧是一个热心肠的以绪塔尔男孩，年纪轻轻就掌握了火焰的元素公理，还发现了一种全新的东西：安心火。有了全新的能力，米利欧打算帮全家结束流放的生活，进入育恩塔尔——就像祖母曾经那样。横穿以绪塔尔的密林，来到以绪奥肯以后，如今的米利欧准备直面维达利安并加入育恩塔尔，但他并不清楚在前方等待他的是什么样的试炼——和什么样的危险。","isVisibleInClient":true,"tacticalInfo":{"style":8,"difficulty":1,"damageType":"kMagic","attackType":"ranged"},"playstyleInfo":{"damage":1,"durability":1,"crowdControl":2,"mobility":1,"utility":3},"championTagInfo":{"championTagPrimary":"友军保护","championTagSecondary":"群体效果"},"squarePortraitPath":"/lol-game-data/assets/v1/champion-icons/902.png","stingerSfxPath":"/lol-game-data/assets/v1/champion-sfx-audios/902.ogg","chooseVoPath":"/lol-game-data/assets/v1/champion-choose-vo/902.ogg","banVoPath":"/lol-game-data/assets/v1/champion-ban-vo/902.ogg","roles":["support","mage"],"recommendedItemDefaults":[],"skins":[{"id":902000,"contentId":"6dc124d1-65b1-49cf-afa2-c49256d9ee5f","isBase":true,"name":"明烛","skinClassification":"kChampion","splashPath":"/lol-game-data/assets/ASSETS/Characters/Milio/Skins/Base/Images/Milio_splash_centered_0.jpg","uncenteredSplashPath":"/lol-game-data/assets/ASSETS/Characters/Milio/Skins/Base/Images/Milio_splash_uncentered_0.jpg","tilePath":"/lol-game-data/assets/ASSETS/Characters/Milio/Skins/Base/Images/Milio_splash_tile_0.jpg","loadScreenPath":"/lol-game-data/assets/ASSETS/Characters/Milio/Skins/Base/MilioLoadscreen_0.jpg","skinType":"","rarity":"kNoRarity","isLegacy":false,"splashVideoPath":null,"previewVideoUrl":null,"collectionSplashVideoPath":null,"collectionCardHoverVideoPath":null,"featuresText":null,"chromaPath":null,"emblems":null,"regionRarityId":0,"rarityGemPath":null,"skinLines":null,"description":null},{"id":902001,"contentId":"7f8c8fb2-fabd-4053-8818-395a0c94b904","isBase":false,"name":"花仙贤者 米利欧","skinClassification":"kChampion","splashPath":"/lol-game-data/assets/ASSETS/Characters/Milio/Skins/Skin01/Images/milio_splash_centered_1.jpg","uncenteredSplashPath":"/lol-game-data/assets/ASSETS/Characters/Milio/Skin