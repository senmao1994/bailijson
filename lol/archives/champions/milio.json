:"/lol-game-data/assets/v1/champion-chroma-images/902/902019.png","colors":["#ECF9F8","#ECF9F8"],"descriptions":[],"description":"","rarities":[]}],"emblems":null,"regionRarityId":0,"rarityGemPath":null,"skinLines":[{"id":205}],"description":"米利欧一直很喜欢水，并且和他那由抒情呱者们组成的青蛙家族一起长大意味着从来不缺少雨水。但它们最近失去了唱歌的能力并且土地变得干涸，于是他就承担起了新的责任。他把他的家人们召集到背包里，启程去恢复他们的歌声，并像新的牧雨者一样学习他们的歌曲。"},{"id":902020,"contentId":"5a88330e-4ea6-4b8a-8baa-f15746d0f508","isBase":false,"name":"冬境仙灵 米利欧","skinClassification":"kChampion","splashPath":"/lol-game-data/assets/ASSETS/Characters/Milio/Skins/Skin20/Images/milio_splash_centered_20.SKINS_Milio_Skin20.jpg","uncenteredSplashPath":"/lol-game-data/assets/ASSETS/Characters/Milio/Skins/Skin20/Images/milio_splash_uncentered_20.SKINS_Milio_Skin20.jpg","tilePath":"/lol-game-data/assets/ASSETS/Characters/Milio/Skins/Skin20/Images/milio_splash_tile_20.SKINS_Milio_Skin20.jpg","loadScreenPath":"/lol-game-data/assets/ASSETS/Characters/Milio/Skins/Skin20/MilioLoadScreen_20.SKINS_Milio_Skin20.jpg","loadScreenVintagePath":"/lol-game-data/assets/ASSETS/Characters/Milio/Skins/Skin20/MilioLoadScreen_20_LE.SKINS_Milio_Skin20.jpg","skinType":"","rarity":"kEpic","isLegacy":false,"splashVideoPath":null,"previewVideoUrl":null,"collectionSplashVideoPath":null,"collectionCardHoverVideoPath":null,"featuresText":null,"chromaPath":"/lol-game-data/assets/v1/champion-chroma-images/902/902020.png","chromas":[{"id":902021,"name":"冬境仙灵 米利欧 焰阳","contentId":"0264230f-d0ea-439f-95cd-57b8f88edf93","skinClassification":"kRecolor","chromaPath":"/lol-game-data/assets/v1/champion-chroma-images/902/902021.png","tilePath":"/lol-game-data/assets/v1/champion-chroma-images/902/902021.png","colors":["#D33528","#D33528"],"descriptions":[{"region":"riot","description":"这个炫彩曾在2025年期间作为礼包专属发布。"}],"description":"这个炫彩曾在2025年期间作为礼包专属发布。","rarities":[{"region":"riot","rarity":1}]},{"id":902022,"name":"冬境仙灵 米利欧 荧火","contentId":"12aaef0e-a8eb-486e-8bb9-a96edae4566d","skinClassification":"kRecolor","chromaPath":"