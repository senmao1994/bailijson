1","skinClassification":"kRecolor","chromaPath":"/lol-game-data/assets/v1/champion-chroma-images/516/516035.png","tilePath":"/lol-game-data/assets/v1/champion-chroma-images/516/516035.png","colors":["#73BFBE","#73BFBE"],"descriptions":[],"description":"","rarities":[]},{"id":516036,"name":"神盾机甲 奥恩 天神飓翼","contentId":"6cd995c8-b73b-431b-8624-1b2c65c246b8","skinClassification":"kRecolor","chromaPath":"/lol-game-data/assets/v1/champion-chroma-images/516/516036.png","tilePath":"/lol-game-data/assets/v1/champion-chroma-images/516/516036.png","colors":["#ECF9F8","#ECF9F8"],"descriptions":[],"description":"","rarities":[]},{"id":516037,"name":"神盾机甲 奥恩 冥神铁翼","contentId":"be5001b2-49b7-4b4b-95f8-643cdaf8ced4","skinClassification":"kRecolor","chromaPath":"/lol-game-data/assets/v1/champion-chroma-images/516/516037.png","tilePath":"/lol-game-data/assets/v1/champion-chroma-images/516/516037.png","colors":["#27211C","#27211C"],"descriptions":[],"description":"","rarities":[]}],"emblems":null,"regionRarityId":0,"rarityGemPath":null,"skinLines":[{"id":226}],"description":"奥恩是一位技艺精湛的机甲修建者，自然而然地成为了加里奥小队的首席工程师。他神情严肃沉稳，以不知疲倦的维修工作展现着自己的奉献精神，从不理会队长想要惹他发笑的徒劳尝试。奥恩内心深处坚信他们的任务终将成功——而当成功之后，他打算在一个远离所有其他人的地方给自己打造一个家。"}],"passive":{"name":"活体锻炉","abilityIconPath":"/lol-game-data/assets/ASSETS/Characters/Ornn/HUD/Icons2D/OrnnP.png","abilityVideoPath":"champion-abilities/0516/ability_0516_P1.webm","abilityVideoImagePath":"champion-abilities/0516/ability_0516_P1.jpg","description":"奥恩可使所有来源的护甲和魔抗加成获得额外提升。<br><br>奥恩可在地图的任意位置上花费金钱来锻造非消耗品的装备。<br><br>此外，他能为他自己和友方英雄打造杰作武器。"},"spells":[{"spellKey":"q","name":"火山突堑","abilityIconPath":"/lol-game-data/assets/ASSETS/Characters/Ornn/HUD/Icons2D/OrnnQ.png","abilityVideoPath":"champion-abilities/0516/ability_0516_Q1.webm","abilityVideoImagePath":"champion-abilities/0516/ability_0516_Q1.jpg","cost":"@Cost@ @AbilityResourceName@","cooldown":"@Cooldown@秒 %i:cooldown%","description":"奥恩猛砸地面，形成一道裂隙来伤害并减速被击中的敌人们。在一阵短暂的延迟后，一个熔岩之柱会在裂隙的终点处形成。","dynamicDescription":"奥恩猛砸地面，创造一道裂隙来造成<physicalDamage>@TotalDamage@物理伤害</physicalDamage>，以及持续@Effect6Amount@秒的@Effect5Amount@%<status>减速</status>。一根熔岩之柱会在裂隙的终点处形成，持续@Effect3Amount@秒。 @SpellModifierDescriptionAppend@","range":[800.0000,800.0000,800.0000,800.0000,800.0000,800.0000],"costCoefficients":[45.0000,45.0000,45.0000,45.0000,45.0000,45.0000],"cooldownCoefficients":[9.0000,8.5000,8.0000,7.5000,7.0000,6.5000],"coefficients":{"coefficient1":1.1000,"coefficient2":0.0000},"effectAmounts":{"Effect1Amount":[20.0000,20.0000,45.0000,70.0000,95.0000,120.0000,145.0000],"Effect2Amount":[1.0000,1.0000,1.0000,1.0000,1.0000,1.0000,1.0000],"Effect3Amount":[4.0000,4.0000,4.0000,4.0000,4.0000,4.0000,4.0000],"Effect4Amount":[0.0000,0.0000,0.0000,0.0000,0.0000,0.0000,0.0000],"Effect5Amount":[40.0000,40.0000,40.0000,40.0000,40.0000,40.0000,40.0000],"Effect6Amount":[2.0000,2.0000,2.0000,2.0000,2.0000,2.0000,2.0000],"Effect7Amount":[0.0000,0.0000,0.0000,0.0000,0.0000,0.0000,0.0000],"Effect8Amount":[0.0000,0.0000,0.0000,0.0000,0.0000,0.0000,0.0000],"Effect9Amount":[0.0000,0.0000,0.0000,0.0000,0.0000,0.0000,0.0000],"Effect10Amount":[0.0000,0.0000,0.0000,0.0000,0.0000,0.0000,0.0000]},"ammo":{"ammoRechargeTime":[0.0000,0.0000,0.0000,0.0000,0.0000,0.0000],"maxAmmo":[0,0,0,0,0,0]},"maxLevel":0},{"spellKey":"w","name":"风箱炎息","abilityIconPath":"/lol-game-data/assets/ASSETS/Characters/Ornn/HUD/Icons2D/OrnnW.png","abilityVideoPath":"champion-abilities/0516/ability_0516_W1.webm","abilityVideoImagePath":"champion-abilities/0516/ability_0516_W1.jpg","cost":"@Cost@ @AbilityResourceName@","cooldown":"@Cooldown@秒 %i:cooldown%","description":"奥恩向前进发，喷出炎息。被最后一阵炎息命中的敌人将变为易碎状态。","dynamicDescription":"奥恩向前不可阻挡地重踏，同时喷吐炎息，在@BreathDuration@秒里持续造成共<magicDamage>@MaxPercentHPPerTickTooltip@%最大生命值的魔法伤害</magicDamage>。被最后一道炎息命中的敌人，会变成<keywordMajor>易碎</keywordMajor>效果，持续@BrittleDuration@秒。<br><br>对<keywordMajor>易碎</keywordMajor>状态的敌人施加的下一个<status>定身</status>效果将使该效果的持续时间提升30%并对目标造成额外的<magicDamage>@BrittlePercentMaxHPCalc@最大生命值的魔法伤害</magicDa